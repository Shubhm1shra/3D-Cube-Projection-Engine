# cube.obj — unit cube centred at the origin
# Drop this file into your sketch's data/ folder.
#
# Vertices are in the same positions as the original hardcoded cube,
# so the scene will look identical to before.

o Cube

v -0.5 -0.5  0.5
v -0.5  0.5  0.5
v  0.5  0.5  0.5
v  0.5 -0.5  0.5
v -0.5 -0.5 -0.5
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v  0.5 -0.5 -0.5

# Faces — OBJ is 1-indexed
# Front and back quads
f 1 2 3 4
f 5 6 7 8

# Connecting edges (expressed as degenerate 2-vertex "faces")
# The loader and edge-drawing code handle 2-vertex faces correctly —
# they draw a single line segment, exactly like the original lateral edges.
f 1 5
f 2 6
f 3 7
f 4 8
